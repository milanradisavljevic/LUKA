{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lehr-suite/bridge/schema.json",
  "title": "NATASCHA → LUA Korrektur-Export (Bridge v1)",
  "description": "Vertrag für die Datei-Brücke: NATASCHA schreibt pro Klasse/Aufgabe eine JSON-Datei nach bridge/inbox/, LUA liest sie in Step0 und generiert gezielte Übungen.",
  "type": "object",
  "required": ["schemaVersion", "klasse", "aufgabe", "fach", "datum", "heatmap"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Format-Version. LUA lehnt unbekannte Versionen freundlich ab."
    },
    "klasse": { "type": "string", "minLength": 1, "examples": ["6i"] },
    "aufgabe": { "type": "string", "minLength": 1, "examples": ["SA2"] },
    "fach": { "type": "string", "enum": ["deutsch", "englisch"] },
    "schulstufe": { "type": "string", "enum": ["oberstufe", "unterstufe"] },
    "textsorte": { "type": "string", "examples": ["Kommentar"] },
    "datum": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "YYYY-MM-DD"
    },
    "anzahlAbgaben": { "type": "integer", "minimum": 0 },
    "heatmap": {
      "type": "array",
      "description": "Klassenweite Fehlerverteilung (grob). NATASCHA kennt nur diese 4 Kategorien.",
      "items": {
        "type": "object",
        "required": ["typ", "kategorie", "anzahl"],
        "additionalProperties": false,
        "properties": {
          "typ": { "type": "string", "enum": ["R", "G", "Z", "A"] },
          "kategorie": {
            "type": "string",
            "enum": ["Rechtschreibung", "Grammatik", "Zeichensetzung", "Ausdruck/Stil"]
          },
          "anzahl": { "type": "integer", "minimum": 0 },
          "prozent": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    },
    "beispiele": {
      "type": "array",
      "description": "Echte (anonymisierte) Schülerfehler — liefern die didaktische Zielgenauigkeit für den LUA-Prompt.",
      "items": {
        "type": "object",
        "required": ["typ", "zitat", "korrektur"],
        "additionalProperties": false,
        "properties": {
          "typ": { "type": "string", "enum": ["R", "G", "Z", "A"] },
          "zitat": { "type": "string", "description": "Fehlerhafte Stelle (anonymisiert)." },
          "korrektur": { "type": "string", "description": "Korrekte Fassung." },
          "erklaerung": { "type": "string" },
          "haeufigkeit": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "empfehlungen": {
      "type": "array",
      "description": "Optional: LLM-Empfehlungen aus klassen_briefing, falls vorhanden.",
      "items": { "type": "string" }
    }
  }
}
