{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "LUKA - Lehrunterlagen-Tool",
  "version": "1.0.0",
  "identifier": "com.lehrunterlagen.tool",
  "build": {
    "beforeDevCommand": "pnpm --filter @lehrunterlagen/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @lehrunterlagen/web build",
    "frontendDist": "../apps/web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Luka — Lehrunterlagen-Applikation",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://api.anthropic.com https://api.openai.com https://api.deepseek.com https://api.mistral.ai https://dashscope.aliyuncs.com https://api.moonshot.ai"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBQjc4MjU1QUJDMzY4M0EKUldRNmFNT3JWWUszMnRLWGNCNUsyZmhZU2tPQ3lGLzRuSDlla1pzVC9iYWFXMVNWMjE4dlArWHEK",
      "endpoints": [
        "https://github.com/milanradisavljevic/LUKA/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
